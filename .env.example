DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/newssou?schema=public"
NEXTAUTH_SECRET="<GENERATE_WITH: openssl rand -base64 32>"
NEXT_PUBLIC_SITE_URL="https://le24.ma"
NEXT_PUBLIC_SITE_NAME="Le24"
ADMIN_EMAIL="admin@le24.ma"
ADMIN_PASSWORD="<STRONG_PASSWORD_MIN_12_CHARS>"

# Upload images (production Vercel — choisir l'une des options)
# Option 1 : Vercel Blob (Storage → Blob dans le dashboard Vercel)
# BLOB_STORE_ID et VERCEL_OIDC_TOKEN sont ajoutés automatiquement
# Si l'upload échoue, ajoutez aussi le token manuel :
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# BLOB_ACCESS="private"
# Option 2 : Cloudinary (https://cloudinary.com)
# CLOUDINARY_CLOUD_NAME="..."
# CLOUDINARY_API_KEY="..."
# CLOUDINARY_API_SECRET="..."

# Publicités — Google AdSense (optionnel)
NEXT_PUBLIC_ADS_ENABLED="true"
# NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXXXXXXXX"
# NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT="XXXXXXXXXX"
# Emplacements spécifiques (optionnel) :
# NEXT_PUBLIC_ADSENSE_SLOT_HEADER_BANNER="..."
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR="..."
